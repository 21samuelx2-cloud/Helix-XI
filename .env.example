# Server
PORT=3001
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3002

# Core auth
JWT_SECRET=replace_with_jwt_secret

# Admin login
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=replace_with_bcrypt_hash
ADMIN_DISPLAY_NAME=Your Name

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=replace_with_supabase_service_role_key
SUPABASE_ANON_KEY=replace_with_supabase_anon_key

# Session
SESSION_SECRET=replace_with_session_secret
SECRET_VAULT_KEY=replace_with_32_byte_hex_or_strong_passphrase

# AI + email
GROQ_API_KEY=replace_with_groq_api_key
RESEND_API_KEY=replace_with_resend_api_key
ALERT_EMAIL=finance@example.com

# Webhooks
WEBHOOK_SECRET=replace_with_default_webhook_secret
# Optional processor-specific overrides:
# WEBHOOK_SECRET_STRIPE=replace_with_stripe_webhook_secret
# WEBHOOK_SECRET_PAYSTACK=replace_with_paystack_webhook_secret
# WEBHOOK_SECRET_FLUTTERWAVE=replace_with_flutterwave_webhook_secret

# Plaid
PLAID_CLIENT_ID=replace_with_plaid_client_id
PLAID_SECRET=replace_with_plaid_secret
PLAID_ENV=sandbox

# Bulk loader
BULK_USERNAME=your_username_or_email
BULK_PASSWORD=your_plain_text_password

# Frontend / admin local API target
REACT_APP_API_URL=http://localhost:3001
